    "updateRule": "@request.auth.id != ''",
    "deleteRule": "@request.auth.id != ''"
  },
  {
    "id": "participants001",
    "name": "participants",
    "type": "base",
    "schema": [
      { "name": "nombre", "type": "text", "required": true },
      { "name": "id_evento", "type": "relation", "required": true, "options": { "collectionId": "events0000000001", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "creado_por", "type": "relation", "required": true, "options": { "collectionId": "_pb_users_auth_", "maxSelect": 1 } }
    ],
    "listRule": "@request.auth.id != ''",
    "viewRule": "@request.auth.id != ''",
    "createRule": "@request.auth.id != ''",
    "updateRule": "@request.auth.id != ''",
    "deleteRule": "@request.auth.id != ''"
  },
  {
    "id": "expenses0000001",
    "name": "expenses",
    "type": "base",
    "schema": [
      { "name": "descripcion", "type": "text", "required": true },
      { "name": "monto", "type": "number", "required": true },
      { "name": "pagado_por", "type": "relation", "required": true, "options": { "collectionId": "participants001", "maxSelect": 1 } },
      { "name": "id_evento", "type": "relation", "required": true, "options": { "collectionId": "events0000000001", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "estado", "type": "text" },
      { "name": "creado_por", "type": "relation", "required": true, "options": { "collectionId": "_pb_users_auth_", "maxSelect": 1 } }
    ],
    "listRule": "@request.auth.id != ''",
    "viewRule": "@request.auth.id != ''",
    "createRule": "@request.auth.id != ''",
    "updateRule": "@request.auth.id != ''",
    "deleteRule": "@request.auth.id != ''"
  },
  {
    "id": "pbc_2043906845",
    "name": "payment_status",
    "type": "base",
    "schema": [
      { "name": "id_evento", "type": "relation", "required": true, "options": { "collectionId": "events0000000001", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "id_pagador", "type": "relation", "required": true, "options": { "collectionId": "participants001", "maxSelect": 1 } },
      { "name": "id_receptor", "type": "relation", "required": true, "options": { "collectionId": "participants001", "maxSelect": 1 } },
      { "name": "monto", "type": "number", "required": true },
      { "name": "creado_por", "type": "relation", "required": true, "options": { "collectionId": "_pb_users_auth_", "maxSelect": 1 } }
    ],
    "listRule": "@request.auth.id != ''",
    "viewRule": "@request.auth.id != ''",
    "createRule": "@request.auth.id != ''",
    "updateRule": "@request.auth.id != ''",
    "deleteRule": "@request.auth.id != ''"
  },
  {
    "id": "pbc_752665753",
    "name": "mensajes",
    "type": "base",
    "schema": [
      { "name": "id_evento", "type": "relation", "options": { "collectionId": "events0000000001", "maxSelect": 1 } },
      { "name": "emisor_id", "type": "relation", "required": true, "options": { "collectionId": "_pb_users_auth_", "maxSelect": 1 } },
      { "name": "receptor_id", "type": "relation", "required": true, "options": { "collectionId": "_pb_users_auth_", "maxSelect": 1 } },
      { "name": "tipo", "type": "text", "required": true },
      { "name": "contenido", "type": "text", "required": true },
      { "name": "leido", "type": "bool" }
    ],
    "listRule": "@request.auth.id != '' && (emisor_id = @request.auth.id || receptor_id = @request.auth.id)",
    "viewRule": "@request.auth.id != '' && (emisor_id = @request.auth.id || receptor_id = @request.auth.id)",
    "createRule": "@request.auth.id != ''",
    "updateRule": "@request.auth.id != '' && (emisor_id = @request.auth.id || receptor_id = @request.auth.id)",
    "deleteRule": "@request.auth.id != '' && (emisor_id = @request.auth.id || receptor_id = @request.auth.id)"
  },
  {
    "name": "payment_methods",
    "type": "base",
    "listRule": "@request.auth.id = user_id",
    "viewRule": "@request.auth.id != ''",
    "createRule": "@request.auth.id != ''",
    "updateRule": "@request.auth.id = user_id",
    "deleteRule": "@request.auth.id = user_id",
    "fields": [
      { "name": "user_id",       "type": "relation", "required": true,  "collectionId": "_pb_users_auth_", "maxSelect": 1 },
      { "name": "tipo",          "type": "select",   "required": true,  "values": ["telefono","banco"], "maxSelect": 1 },
      { "name": "telefono",      "type": "text" },
      { "name": "etiquetas",     "type": "select",   "values": ["yape","plin","ambos"], "maxSelect": 1 },
      { "name": "banco",         "type": "text" },
      { "name": "numero_cuenta", "type": "text" },
      { "name": "cci",           "type": "text" },
      { "name": "moneda",        "type": "select",   "values": ["SOL","USD"], "maxSelect": 1 },
      { "name": "alias",         "type": "text" }
    ]
  }
]
